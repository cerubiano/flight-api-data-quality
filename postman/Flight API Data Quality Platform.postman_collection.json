                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Test 1 — Validate response status",
                      "pm.test(\"Status code is 201\", function () {",
                      "    pm.response.to.have.status(201);",
                      "});",
                      "",
                      "// Test 2 — Validate response has flight offers",
                      "pm.test(\"Response contains flight offers\", function () {",
                      "    const response = pm.response.json();",
                      "    pm.expect(response.data.offers).to.be.an('array');",
                      "    pm.expect(response.data.offers.length).to.be.above(0);",
                      "});",
                      "",
                      "// Test 3 — Validate price fields are present",
                      "pm.test(\"Price fields are present\", function () {",
                      "    const response = pm.response.json();",
                      "    const offer = response.data.offers[0];",
                      "    pm.expect(offer.total_amount).to.exist;",
                      "    pm.expect(offer.base_amount).to.exist;",
                      "    pm.expect(offer.total_currency).to.exist;",
                      "});",
                      "",
                      "// Test 4 — Validate schedule fields are present",
                      "pm.test(\"Schedule fields are present\", function () {",
                      "    const response = pm.response.json();",
                      "    const segment = response.data.offers[0].slices[0].segments[0];",
                      "    pm.expect(segment.origin.iata_code).to.exist;",
                      "    pm.expect(segment.destination.iata_code).to.exist;",
                      "    pm.expect(segment.departing_at).to.exist;",
                      "    pm.expect(segment.arriving_at).to.exist;",
                      "});",
                      "",
                      "// Test 5 — Validate baggage fields are present",
                      "pm.test(\"Baggage fields are present\", function () {",
                      "    const response = pm.response.json();",
                      "    const passenger = response.data.offers[0].slices[0].segments[0].passengers[0];",
                      "    pm.expect(passenger.baggages).to.be.an('array');",
                      "});"
