                  "if (response.data && response.data.length > 0) {",
                  "    ",
                  "    // Save the first offer ID as a collection variable",
                  "    pm.collectionVariables.set(\"amadeus_offer_id\", response.data[0].id);",
                  "    ",
                  "    // Log the saved offer ID to the Postman console",
                  "    console.log(\"Offer ID saved:\", response.data[0].id);",
