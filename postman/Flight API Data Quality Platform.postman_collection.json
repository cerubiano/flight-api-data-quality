            {
              "name": "Happy Path — Valid Search",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Test 1 — Validate response status",
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "// Test 2 — Validate response has flight offers",
                      "pm.test(\"Response contains flight offers\", function () {",
                      "    const response = pm.response.json();",
                      "    pm.expect(response.data).to.be.an('array');",
                      "    pm.expect(response.data.length).to.be.above(0);",
                      "});",
                      "",
                      "// Test 3 — Validate price fields are present",
                      "pm.test(\"Price fields are present\", function () {",
                      "    const response = pm.response.json();",
                      "    const offer = response.data[0];",
                      "    pm.expect(offer.price.grandTotal).to.exist;",
                      "    pm.expect(offer.price.base).to.exist;",
                      "    pm.expect(offer.price.currency).to.exist;",
                      "});",
                      "",
                      "// Test 4 — Validate schedule fields are present",
                      "pm.test(\"Schedule fields are present\", function () {",
                      "    const response = pm.response.json();",
                      "    const segment = response.data[0].itineraries[0].segments[0];",
                      "    pm.expect(segment.departure.iataCode).to.exist;",
                      "    pm.expect(segment.arrival.iataCode).to.exist;",
                      "    pm.expect(segment.departure.at).to.exist;",
                      "    pm.expect(segment.arrival.at).to.exist;",
                      "});",
                      "",
                      "// Test 5 — Validate baggage fields are present",
                      "pm.test(\"Baggage fields are present\", function () {",
                      "    const response = pm.response.json();",
                      "    const fareDetails = response.data[0].travelerPricings[0].fareDetailsBySegment[0];",
                      "    pm.expect(fareDetails.includedCheckedBags).to.exist;",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
